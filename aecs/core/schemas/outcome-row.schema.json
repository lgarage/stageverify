{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AECS outcome row schema",
  "type": "object",
  "required": [
    "date",
    "repo",
    "archetype",
    "model",
    "tier",
    "confStart",
    "confAfter",
    "outcome",
    "machine",
    "note"
  ],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "repo": { "type": "string" },
    "archetype": { "type": "string" },
    "model": { "type": "string" },
    "tier": { "type": "string" },
    "confStart": { "type": "number", "minimum": 0, "maximum": 100 },
    "confAfter": { "type": "number", "minimum": 0, "maximum": 100 },
    "outcome": { "type": "string", "enum": ["ok", "fail", "escalate"] },
    "machine": { "type": "string" },
    "note": { "type": "string", "maxLength": 80 }
  },
  "additionalProperties": false
}
