    "6": {
      "label": "MODEL_DOSSIER index",
      "when": "Model routing, QR/zones, backend-critical, or dossier-tagged domain work",
      "source": ".cursor/rules/composer-orchestrator.mdc step 6",
      "action": "Read MODEL_DOSSIER index (lines 7–23); open exactly one § by tag via dossier:slice — never load full dossier"
    },
    "7": {
      "label": "§ agent-lessons + LIBRARIAN_LESSONS",
      "when": "Public routes, pickup portal, vendor receive, or UI fixes on unauthenticated flows",
      "source": ".cursor/rules/composer-orchestrator.mdc step 7",
      "action": "Read LIBRARIAN_LESSONS § slice via npm run context:lessons -- --type <type>/<subtype> (after archetype gate); npm run dossier:slice -- --tag agent-lessons for domain depth before Receive/Pickup/public routes"
    },
    "8": {
      "label": "USER_SCOPE_REJECTIONS",
      "when": "Dispatcher portal nav, Settings IA, sidebar, or Vendors vs Settings merge",
      "source": ".cursor/rules/composer-orchestrator.mdc step 8",
      "action": "Read PROJECT_STATUS/USER_SCOPE_REJECTIONS.md (≤8 rows) — do not re-introduce rejected nav"
    }
