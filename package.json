{
  "name": "stageverify",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://lgarage.github.io/stageverify",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:pickup": "node scripts/reset-pickup-verify-fixture.mjs && npx tsx scripts/seed-pickup-verify-readiness.mjs && node scripts/verify-pickup-portal.mjs",
    "reset:pickup-verify": "node scripts/reset-pickup-verify-fixture.mjs",
    "seed:pickup-verify-readiness": "npx tsx scripts/seed-pickup-verify-readiness.mjs",
    "verify:material-issue-dashboard": "node scripts/verify-material-issue-dashboard.mjs",
    "verify:pickup:prod": "node scripts/reset-pickup-verify-fixture.mjs --base-url=https://lgarage.github.io/stageverify && npx tsx scripts/seed-pickup-verify-readiness.mjs --require-deployed-cf && node scripts/verify-pickup-portal.mjs --base-url=https://lgarage.github.io/stageverify",
    "reset:receive-verify": "node scripts/reset-receive-verify-fixture.mjs",
    "verify:receive": "node scripts/reset-receive-verify-fixture.mjs && node scripts/verify-receive.mjs",
    "verify:receive:prod": "node scripts/verify-receive.mjs --base-url=https://lgarage.github.io/stageverify",
    "seed:vendor-demo": "node scripts/seed-vendor-demo-deliveries.mjs",
    "verify:vendor-demo": "node scripts/verify-vendor-demo.mjs",
    "seed:vendor-pins": "node scripts/seed-vendor-pin-data.mjs",
    "verify:vendor-pin": "node scripts/seed-vendor-pin-data.mjs && node scripts/verify-vendor-pin.mjs",
    "verify:vendor-pin:prod": "node scripts/verify-vendor-pin.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:vendor-demo:prod": "node scripts/verify-vendor-demo.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:vendor-demo:webkit": "node scripts/verify-vendor-demo.mjs --browser=webkit",
    "verify:vendor-demo:webkit:prod": "node scripts/verify-vendor-demo.mjs --browser=webkit --base-url=https://lgarage.github.io/stageverify",
    "verify:vendor-ios-rest": "node scripts/verify-vendor-ios-rest.mjs",
    "verify:vendor-ios-rest:prod": "node scripts/verify-vendor-ios-rest.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:vendor-pin:webkit:prod": "node scripts/verify-vendor-pin-webkit.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:vendor-ios-latency:prod": "node scripts/verify-vendor-ios-rest-slow.mjs --base-url=https://lgarage.github.io/stageverify",
    "reset:vendor-demo": "node scripts/reset-vendor-demo-fixture.mjs",
    "open:vendor-demo-qr": "cmd /c start https://lgarage.github.io/stageverify/#/demo/vendor-scan",
    "show:vendor-qr": "node scripts/show-vendor-qr.mjs",
    "open:pickup-demo-qr": "cmd /c start https://lgarage.github.io/stageverify/#/demo/pickup-scan",
    "verify:vendor-e2e": "node scripts/reset-vendor-demo-fixture.mjs && node scripts/set-vendor-delivery-mode.mjs full_checkin && node scripts/seed-vendor-pin-data.mjs && node scripts/verify-vendor-e2e.mjs",
    "verify:vendor-e2e:prod": "node scripts/verify-vendor-e2e.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:vendor-delivered": "node scripts/reset-vendor-demo-fixture.mjs && node scripts/set-vendor-delivery-mode.mjs exception_only && node scripts/seed-vendor-pin-data.mjs && node scripts/verify-vendor-delivered.mjs",
    "verify:vendor-delivered:prod": "node scripts/reset-vendor-demo-fixture.mjs && node scripts/set-vendor-delivery-mode.mjs exception_only && node scripts/seed-vendor-pin-data.mjs && node scripts/verify-vendor-delivered.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:settings-staging": "node scripts/verify-settings-staging.mjs",
    "verify:portal-layout": "node scripts/verify-portal-layout.mjs",
    "verify:dispatcher-nav": "node scripts/verify-dispatcher-nav.mjs",
    "verify:phase5-email": "node scripts/verify-phase5-email.mjs",
    "verify:email-oauth-connect": "node scripts/verify-email-oauth-connect.mjs",
    "verify:phase3-integration": "node scripts/verify-phase3-integration.mjs",
    "verify:phase4-integration": "node scripts/verify-phase4-integration.mjs",
    "verify:phase4-integration:prod": "node scripts/verify-phase4-integration.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:pickup-issue-report": "node scripts/verify-pickup-issue-report.mjs",
    "verify:pickup-issue-resolution": "node scripts/verify-pickup-issue-resolution-readback.mjs",
    "verify:pickup-issue-resolution:prod": "node scripts/verify-pickup-issue-resolution-readback.mjs --base-url=https://lgarage.github.io/stageverify",
    "verify:public-network-error": "node scripts/verify-public-network-error.mjs",
    "verify:settings-staging:prod": "node scripts/verify-settings-staging.mjs --base-url=https://lgarage.github.io/stageverify",
    "clean:verify-artifacts": "node scripts/clean-verify-artifacts.mjs",
    "measure:routes": "node scripts/measure-mobile-route-performance.mjs",
    "measure:vendor-submit-latency": "node scripts/measure-vendor-submit-latency.mjs",
    "aecs:install": "node aecs/installer/install.mjs",
    "aecs:install:write": "node aecs/installer/install.mjs --write",
    "aecs:verify": "node aecs/installer/verify.mjs",
    "aecs:update": "node aecs/updater/update.mjs",
    "aecs:update:write": "node aecs/updater/update.mjs --write",
    "aecs:rollback": "node aecs/updater/rollback.mjs",
    "aecs:rollback:list": "node aecs/updater/rollback.mjs --list",
    "aecs:rollback:write": "node aecs/updater/rollback.mjs --write",
    "aecs:export": "node aecs/release/export.mjs",
    "aecs:export:write": "node aecs/release/export.mjs --write",
    "aecs:test": "node --test aecs/installer/paths.test.mjs aecs/installer/install.test.mjs aecs/updater/update.test.mjs aecs/updater/hardening.test.mjs aecs/updater/rollback-progress.test.mjs aecs/release/export.test.mjs",
    "test:mark-vendor-delivered": "cd functions && npm run build && cd .. && firebase emulators:exec --only firestore,functions \"node scripts/test-mark-vendor-delivered.mjs\"",
    "test:firestore-rules": "firebase emulators:exec --only firestore \"node scripts/test-delivery-status-transitions.mjs\"",
    "test:pickup-authority": "cd functions && npm run build && cd .. && firebase emulators:exec --only firestore,functions \"node scripts/test-pickup-authority.mjs\"",
    "test:auto-submit-readiness": "cd functions && npm run build && cd .. && firebase emulators:exec --only firestore,functions \"node scripts/test-auto-submit-readiness.mjs\"",
    "test:readiness": "npx tsx scripts/test-readiness-two-source.mjs",
    "test:evidence-alignment": "npx tsx scripts/test-evidence-model-alignment.mjs",
    "test:email-parser": "npx tsx scripts/test-email-parser.mjs",
    "test:gmail-api": "npx tsx scripts/test-gmail-api.mjs",
    "test:send-vendor-email": "cd functions && npm run build && cd .. && firebase emulators:exec --only auth,firestore,functions \"node scripts/test-send-vendor-email.mjs\"",
    "test:process-inbound-vendor-email": "cd functions && npm run build && cd .. && firebase emulators:exec --only auth,firestore,functions \"npx tsx scripts/test-process-inbound-vendor-email.mjs\"",
    "away:validate": "node scripts/away-validate.mjs",
    "away:next": "node scripts/away-next.mjs",
    "away:plan": "node scripts/away-plan.mjs",
    "away:batch": "node scripts/away-batch.mjs",
    "away:preflight": "node scripts/away-preflight.mjs",
    "away:sync-next": "node scripts/away-sync-next.mjs",
    "away:ship": "node scripts/away-ship.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "firebase": "^12.14.0",
    "html5-qrcode": "^2.3.8",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "_vendorVerifyScriptsDoc": {
    "verify:vendor-delivered:prod": "CANONICAL prod — demo QR through exception-only Delivered hub",
    "verify:vendor-demo": "LEGACY full_checkin — item checkoff + zone step",
    "verify:vendor-demo:prod": "LEGACY full_checkin prod — not canonical; use verify:vendor-delivered:prod"
  }
}
