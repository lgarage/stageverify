rules_version = '2';

// stageverify Firestore Security Rules
// ------------------------------------
// Access model (Phase 2 privacy hardening):
//
// PUBLIC READ (no auth): stagingLocations, appSettings, shopStockLocationMappings
//   - Location/branding for pre-PIN receive and pickup location labels only.
//   - Sensitive delivery/item/job/PO data is CF-mediated (vendor session or pickup token).
//
// AUTH REQUIRED READ: deliveries, items, jobs, purchaseOrders, statusHistory, pickupEvents
//   - Dispatcher/settings UI and audit views require Firebase Auth.
//
// UNAUTHENTICATED WRITES: none on deliveries/items/statusHistory
//   - Vendor writes via session-gated Cloud Functions (Admin SDK).
//   - Pickup writes via token-gated Cloud Functions (Admin SDK).
//   - Readiness promotion: recalculateDeliveryReadiness CF (Admin SDK) only.
//
// AUTHENTICATED WRITES (dispatcher/settings UI):
//   - deliveries: full create/update/delete
//   - purchaseOrders, vendors, jobs: create/update
//   - stagingLocations: create/update/delete
//   - appSettings: write
//   - items: full create/update/delete (managed by dispatcher flows)
//
// Cloud Functions use the Admin SDK and bypass these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDispatcher() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/dispatcherRoles/$(request.auth.uid))
        && get(/databases/$(database)/documents/dispatcherRoles/$(request.auth.uid)).data.active != false;
    }

    function isValidDeliveryStatus(status) {
      return status in [
        'pending',
        'shipped',
        'arrived',
        'partial',
        'ready_for_pickup',
        'complete',
        'issue',
        'picked_up',
        'installed',
      ];
    }

    function isValidItemStatus(status) {
      return status in [
        'pending',
        'partial',
        'received',
        'missing',
        'damaged',
        'backordered',
        'installed',
      ];
    }

    match /deliveries/{deliveryId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /items/{itemId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /vendorPinAttempts/{deliveryId} {
      allow read, write: if false;
    }

    // Vendor PIN sessions — CF Admin SDK only; clients hold opaque token locally.
    match /vendorSessions/{sessionId} {
      allow read, write: if false;
    }

    // Pickup tokens — CF Admin SDK only; opaque token shown once at generation.
    match /pickupTokens/{tokenId} {
      allow read, write: if false;
    }

    match /pinVerificationEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /stagingLocations/{locationId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    match /purchaseOrders/{poId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /statusHistory/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /pickupEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update, delete: if false;
    }

    // Phase 3: MaterialIssue — auth read only; writes via Admin SDK (createMaterialIssue CF).
    match /materialIssues/{issueId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /vendorEmailEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Phase 6: Gmail OAuth connection metadata — auth read; tokens CF-only.
    match /emailProviderConnections/{providerId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /emailProviderSecrets/{providerId} {
      allow read, write: if false;
    }

    match /emailOAuthStates/{stateId} {
      allow read, write: if false;
    }

    match /emailProviderAuditEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Inbound Gmail invoice ingestion — dispatcher read; CF Admin SDK writes only.
    match /inboundEmailProcessing/{docId} {
      allow read: if isDispatcher();
      allow create, update, delete: if false;
    }

    // Johnstone invoice import review queue — dispatcher read; no auto-apply to deliveries.
    match /vendorInvoiceImports/{docId} {
      allow read: if isDispatcher();
      allow create, update, delete: if false;
    }

    // Dispatcher role registry — CF Admin SDK writes; self-read for UI hints.
    match /dispatcherRoles/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    match /pickupOperations/{operationId} {
      allow read, write: if false;
    }

    match /appSettings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Phase 3: permanent shop-stock location directory — public read for pickup location labels.
    match /shopStockLocationMappings/{mappingId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
  }
}
