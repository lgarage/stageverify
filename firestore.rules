rules_version = '2';

// stageverify Firestore Security Rules
// ------------------------------------
// Access model:
//
// PUBLIC READ (no auth): deliveries, items, stagingLocations, appSettings
//   - Mobile scan/check-in flows read delivery data, line items, zone codes,
//     and global timing config without signing in.
//   - Vendor PIN sessions: vendorSessions collection (CF Admin SDK only).
//     Vendor check-in writes (submitCheckin) require active delivery-scoped session
//     validated via validateVendorSession CF before client write.
//     vendorPhysicalDropoffConfirmed evidence is written via markVendorDelivered CF only.
//
// AUTH REQUIRED READ: jobs, purchaseOrders, statusHistory, pickupEvents
//   - Dispatcher/settings UI and audit views require Firebase Auth.
//
// UNAUTHENTICATED WRITES (mobile scan/check-in):
//   - deliveries: update only — physical facts + vendor workflow status (never picked_up or ready_for_pickup)
//     Derived readiness summary fields (physicalDropoffComplete*, stagingAssignmentComplete) are CF-only.
//   - items: update only — qtyReceived, qtyMissing, qtyDamaged, status
//   - statusHistory: create only — vendor physical transitions (never picked_up or ready_for_pickup)
//   - pickupEvents / pickupOperations: writes via Admin SDK (recordPickupEvent CF) only
//   - Readiness promotion: recalculateDeliveryReadiness CF (Admin SDK) only
//   - Vendor revert (partial|ready_for_pickup|complete → arrived) is the only intentional backward path.
//   - Terminal states picked_up and installed cannot be reopened without auth.
//
// AUTHENTICATED WRITES (dispatcher/settings UI):
//   - deliveries: full create/update/delete
//   - purchaseOrders, vendors, jobs: create/update
//   - stagingLocations: create/update/delete
//   - appSettings: write
//   - items: full create/update/delete (managed by dispatcher flows)
//
// Cloud Functions use the Admin SDK and bypass these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidDeliveryStatus(status) {
      return status in [
        'pending',
        'shipped',
        'arrived',
        'partial',
        'ready_for_pickup',
        'complete',
        'issue',
        'picked_up',
        'installed',
      ];
    }

    function isValidItemStatus(status) {
      return status in [
        'pending',
        'partial',
        'received',
        'missing',
        'damaged',
        'backordered',
        'installed',
      ];
    }

    // Vendor physical workflow only — no unauth picked_up or ready_for_pickup promotion.
    // Same-status updates are allowed (idempotent vendor DELIVERED / re-submit check-in).
    function unauthDeliveryStatusTransitionAllowed(fromStatus, toStatus) {
      return fromStatus == toStatus
        || (fromStatus == 'pending' && toStatus == 'arrived')
        || (fromStatus == 'shipped' && toStatus == 'arrived')
        || (fromStatus == 'arrived' && toStatus == 'partial')
        || (fromStatus == 'partial' && toStatus == 'arrived')
        || (fromStatus == 'ready_for_pickup' && toStatus == 'arrived')
        || (fromStatus == 'complete' && toStatus == 'arrived');
    }

    // Positive vendor physical evidence is CF-only; unauth may clear on vendor revert.
    function unauthVendorEvidenceWriteAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let d = request.resource.data;
      return (!changed.hasAny(['vendorPhysicalDropoffConfirmed'])
          || d.vendorPhysicalDropoffConfirmed == false)
        && (!changed.hasAny(['vendorPhysicalDropoffConfirmedAt'])
          || d.vendorPhysicalDropoffConfirmedAt == null)
        && (!changed.hasAny(['deliveredAt'])
          || d.deliveredAt == null)
        && (!changed.hasAny(['physicalDropoffSource'])
          || d.physicalDropoffSource == null);
    }

    function unauthDeliveryUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let fromStatus = resource.data.status;
      let toStatus = request.resource.data.status;
      return changed.hasOnly([
          'status',
          'submittedAt',
          'updatedAt',
          'lastCheckmarkAt',
          'stagingLocationId',
          'additionalStagingLocationIds',
          'vendorPhysicalDropoffConfirmed',
          'vendorPhysicalDropoffConfirmedAt',
          'deliveredAt',
          'physicalDropoffSource',
        ])
        && unauthVendorEvidenceWriteAllowed()
        && resource.data.keys().hasAll(['status'])
        && request.resource.data.keys().hasAll(['status'])
        && isValidDeliveryStatus(fromStatus)
        && isValidDeliveryStatus(toStatus)
        && (!changed.hasAny(['status'])
          || unauthDeliveryStatusTransitionAllowed(fromStatus, toStatus));
    }

    function unauthItemUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let d = request.resource.data;
      return changed.hasOnly([
          'qtyReceived',
          'qtyMissing',
          'qtyDamaged',
          'status',
        ])
        && (!changed.hasAny(['status']) || isValidItemStatus(d.status))
        && (!changed.hasAny(['qtyReceived']) || (d.qtyReceived is int && d.qtyReceived >= 0 && d.qtyReceived <= 9999))
        && (!changed.hasAny(['qtyMissing'])  || (d.qtyMissing  is int && d.qtyMissing  >= 0 && d.qtyMissing  <= 9999))
        && (!changed.hasAny(['qtyDamaged'])  || (d.qtyDamaged  is int && d.qtyDamaged  >= 0 && d.qtyDamaged  <= 9999));
    }

    function unauthStatusHistoryCreateAllowed() {
      let d = request.resource.data;
      return d.keys().hasAll(['id', 'entityType', 'entityId', 'toStatus', 'actorType', 'createdAt'])
        && d.entityType == 'delivery_order'
        && d.actorType == 'vendor'
        && isValidDeliveryStatus(d.toStatus)
        && d.toStatus != 'picked_up'
        && d.toStatus != 'ready_for_pickup'
        && d.actorName is string
        && d.actorName.size() <= 128;
    }

    match /deliveries/{deliveryId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated() || unauthDeliveryUpdateAllowed();
    }

    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated() || unauthItemUpdateAllowed();
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /vendorPinAttempts/{deliveryId} {
      allow read, write: if false;
    }

    // Vendor PIN sessions — CF Admin SDK only; clients hold opaque token locally.
    match /vendorSessions/{sessionId} {
      allow read, write: if false;
    }

    // Pickup tokens — CF Admin SDK only; opaque token shown once at generation.
    match /pickupTokens/{tokenId} {
      allow read, write: if false;
    }

    match /pinVerificationEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /stagingLocations/{locationId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    match /purchaseOrders/{poId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /statusHistory/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() || unauthStatusHistoryCreateAllowed();
      allow update, delete: if false;
    }

    match /pickupEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update, delete: if false;
    }

    // Phase 3: MaterialIssue — auth read only; writes via Admin SDK (createMaterialIssue CF).
    match /materialIssues/{issueId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /vendorEmailEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Phase 6: Gmail OAuth connection metadata — auth read; tokens CF-only.
    match /emailProviderConnections/{providerId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /emailProviderSecrets/{providerId} {
      allow read, write: if false;
    }

    match /emailOAuthStates/{stateId} {
      allow read, write: if false;
    }

    match /emailProviderAuditEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /pickupOperations/{operationId} {
      allow read, write: if false;
    }

    match /appSettings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Phase 3: permanent shop-stock location directory — public read for pickup location labels.
    match /shopStockLocationMappings/{mappingId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
  }
}
