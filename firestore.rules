rules_version = '2';

// stageverify Firestore Security Rules
// ------------------------------------
// Access model:
//
// PUBLIC READ (no auth): deliveries, items, stagingLocations, appSettings
//   - Mobile scan/check-in flows read delivery data, line items, zone codes,
//     and global timing config without signing in.
//   - Vendor PINs live in `vendors` (auth-only read). Public flows use denormalized
//     `vendorName` on deliveries; PIN verification is via `verifyVendorPin` Cloud Function.
//
// AUTH REQUIRED READ: jobs, purchaseOrders, statusHistory, pickupEvents
//   - Dispatcher/settings UI and audit views require Firebase Auth.
//
// UNAUTHENTICATED WRITES (mobile scan/check-in):
//   - deliveries: update only — status, submittedAt, updatedAt, lastCheckmarkAt, stagingLocationId, additionalStagingLocationIds
//   - items: update only — qtyReceived, qtyMissing, qtyDamaged, status
//   - statusHistory: create only (append-only audit log)
//   - pickupEvents: create only (append-only pickup log)
//   - Delivery status enum + explicit forward-only transition allowlist on unauthenticated delivery updates.
//     Vendor revert (partial|ready_for_pickup|complete → arrived) is the only intentional backward path.
//     Terminal states picked_up and installed cannot be reopened without auth.
//
// AUTHENTICATED WRITES (dispatcher/settings UI):
//   - deliveries: full create/update/delete
//   - purchaseOrders, vendors, jobs: create/update
//   - stagingLocations: create/update/delete
//   - appSettings: write
//   - items: full create/update/delete (managed by dispatcher flows)
//
// Cloud Functions use the Admin SDK and bypass these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidDeliveryStatus(status) {
      return status in [
        'pending',
        'shipped',
        'arrived',
        'partial',
        'ready_for_pickup',
        'complete',
        'issue',
        'picked_up',
        'installed',
      ];
    }

    function isValidItemStatus(status) {
      return status in [
        'pending',
        'partial',
        'received',
        'missing',
        'damaged',
        'backordered',
        'installed',
      ];
    }

    // Explicit allowlist derived from vendor check-in + technician pickup client write paths.
    // Same-status updates are allowed (idempotent vendor DELIVERED / re-submit check-in).
    function unauthDeliveryStatusTransitionAllowed(fromStatus, toStatus) {
      return fromStatus == toStatus
        || (fromStatus == 'pending' && toStatus == 'arrived')
        || (fromStatus == 'shipped' && toStatus == 'arrived')
        || (fromStatus == 'arrived' && (toStatus == 'partial' || toStatus == 'ready_for_pickup'))
        || (fromStatus == 'partial' && (
          toStatus == 'ready_for_pickup'
          || toStatus == 'arrived'
          || toStatus == 'picked_up'
        ))
        || (fromStatus == 'ready_for_pickup' && (
          toStatus == 'picked_up'
          || toStatus == 'arrived'
        ))
        || (fromStatus == 'complete' && (
          toStatus == 'picked_up'
          || toStatus == 'arrived'
        ));
    }

    function unauthDeliveryUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let fromStatus = resource.data.status;
      let toStatus = request.resource.data.status;
      return changed.hasOnly([
          'status',
          'submittedAt',
          'updatedAt',
          'lastCheckmarkAt',
          'stagingLocationId',
          'additionalStagingLocationIds',
        ])
        && resource.data.keys().hasAll(['status'])
        && request.resource.data.keys().hasAll(['status'])
        && isValidDeliveryStatus(fromStatus)
        && isValidDeliveryStatus(toStatus)
        && (!changed.hasAny(['status'])
          || unauthDeliveryStatusTransitionAllowed(fromStatus, toStatus));
    }

    function unauthItemUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let d = request.resource.data;
      return changed.hasOnly([
          'qtyReceived',
          'qtyMissing',
          'qtyDamaged',
          'status',
        ])
        && (!changed.hasAny(['status']) || isValidItemStatus(d.status))
        && (!changed.hasAny(['qtyReceived']) || (d.qtyReceived is int && d.qtyReceived >= 0 && d.qtyReceived <= 9999))
        && (!changed.hasAny(['qtyMissing'])  || (d.qtyMissing  is int && d.qtyMissing  >= 0 && d.qtyMissing  <= 9999))
        && (!changed.hasAny(['qtyDamaged'])  || (d.qtyDamaged  is int && d.qtyDamaged  >= 0 && d.qtyDamaged  <= 9999));
    }

    function unauthStatusHistoryCreateAllowed() {
      let d = request.resource.data;
      return d.keys().hasAll(['id', 'entityType', 'entityId', 'toStatus', 'actorType', 'createdAt'])
        && d.entityType == 'delivery_order'
        && d.actorType in ['vendor', 'technician']
        && isValidDeliveryStatus(d.toStatus)
        && d.actorName is string
        && d.actorName.size() <= 128;
    }

    function unauthPickupEventCreateAllowed() {
      let d = request.resource.data;
      return d.keys().hasAll(['id', 'deliveryOrderId', 'jobId', 'technicianName', 'pickedUpAt', 'itemsPickedSummary'])
        && d.technicianName is string
        && d.technicianName.size() <= 128;
    }

    match /deliveries/{deliveryId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated() || unauthDeliveryUpdateAllowed();
    }

    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
      allow update: if isAuthenticated() || unauthItemUpdateAllowed();
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /vendorPinAttempts/{deliveryId} {
      allow read, write: if false;
    }

    match /pinVerificationEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /stagingLocations/{locationId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    match /purchaseOrders/{poId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /statusHistory/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() || unauthStatusHistoryCreateAllowed();
      allow update, delete: if false;
    }

    match /pickupEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() || unauthPickupEventCreateAllowed();
      allow update, delete: if false;
    }

    // Phase 3: MaterialIssue — auth read only; writes via Admin SDK (createMaterialIssue CF).
    match /materialIssues/{issueId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /appSettings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
